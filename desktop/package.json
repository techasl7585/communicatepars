{
  "name": "desktop",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production electron electron/main.cjs",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "NODE_ENV=development electron electron/main.cjs",
    "desktop": "concurrently \"npm run dev -- --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && npm run electron\""
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "electron": "^34.5.8",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "vite": "^8.1.0",
    "wait-on": "^7.2.0"
  },
  "main": "electron/main.cjs"
}
